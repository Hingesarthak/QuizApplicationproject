<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".resulteasyset5"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ANSWER LIST"
            android:textSize="45dp"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="45dp"/>

        <!-- Q1 -->
        <TextView
            android:id="@+id/question1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q1. What color are bananas when ripe?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="15dp"/>

        <EditText
            android:id="@+id/edittext1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: Yellow"/>

        <!-- Q2 -->
        <TextView
            android:id="@+id/question2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q2. How many days are there in a leap year?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/edittext3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: 366"/>

        <!-- Q3 -->
        <TextView
            android:id="@+id/question3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q3. What gas do humans need to breathe?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/edittext5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: Oxygen"/>

        <!-- Q4 -->
        <TextView
            android:id="@+id/question4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q4. Which shape has 4 equal sides?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/edittext7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext8"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: Square"/>

        <!-- Q5 -->
        <TextView
            android:id="@+id/question5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q5. What fruit is red and used to make ketchup?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/edittext9"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: Tomato"/>

        <!-- Q6 -->
        <TextView
            android:id="@+id/question6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q6. What do you call water in solid form?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/edittext11"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: Ice"/>

        <!-- Q7 -->
        <TextView
            android:id="@+id/question7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q7. Which bird is known for mimicking sounds?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/edittext13"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext14"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: Parrot"/>

        <!-- Q8 -->
        <TextView
            android:id="@+id/question8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q8. What do cows produce that we drink?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/edittext15"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext16"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: Milk"/>

        <!-- Q9 -->
        <TextView
            android:id="@+id/question9"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q9. What do plants use sunlight for?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/edittext17"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext18"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: Photosynthesis"/>

        <!-- Q10 -->
        <TextView
            android:id="@+id/question10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q10. What is the freezing point of water?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/edittext19"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected Option: "/>

        <EditText
            android:id="@+id/edittext20"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct Option: 0°C"/>

    </LinearLayout>

</ScrollView>
